class MyHashSet:
    def __init__(self):
        self.ans=[]

    def add(self, key: int) -> None:
        if key not in self.ans:
            self.ans.append(key)

    def remove(self, key: int) -> None:
        if key in self.ans:
            self.ans.remove(key)

    def contains(self, key: int) -> bool:
        if key in self.ans:
            return True
        return False
