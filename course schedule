class Solution:
    def canFinish(self, numCourses: int, prerequisites: List[List[int]]) -> bool:
        adj=[]
        for _ in range(0,numCourses):
            adj.append([])
        for n,m in prerequisites:
            adj[m].append(n)
        inDegree=[0]*numCourses
        for i in range(0,numCourses):
            for j in adj[i]:
                inDegree[j]+=1
        q=deque([])
        for i in range(0,numCourses):
            if inDegree[i]==0:
                q.append(i)
        ans=[]
        while(q):
            node=q.popleft()
            ans.append(node)
            for i in adj[node]:
                inDegree[i]-=1
                if inDegree[i]==0:
                    q.append(i)
        return len(ans)==numCourses
