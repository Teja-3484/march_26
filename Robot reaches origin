class Solution:
    def judgeCircle(self, moves: str) -> bool:
        d={
            'U':(0,1),
            'D':(0,-1),
            'R':(1,0),
            'L':(-1,0)
        }
        st=[0,0]
        for i in moves:
            if i=='U':
                st[1]+=1
            elif i=='D':
                st[1]-=1
            elif i=='R':
                st[0]+=1
            else:
                st[0]-=1
        return st==[0,0]
